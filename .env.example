APP_NAME=AI Assistant Platform Backend
APP_ENV=development

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres

HF_SPACE_URL=https://your-space-name.hf.space
HF_GENERATE_PATH=/generate_stream
HF_TIMEOUT_SECONDS=120

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
ALLOW_ANON_CHAT=false

MAX_HISTORY_MESSAGES=10
MAX_USER_MEMORIES=5

# Telegram optional
TELEGRAM_BOT_TOKEN=
BACKEND_CHAT_URL=http://localhost:8000/chat
BACKEND_BEARER_TOKEN=
